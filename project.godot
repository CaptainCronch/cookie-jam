; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Baal's Birthday Bash"
run/main_scene="uid://cgpyq2axecbgx"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/stretch_mode=0
boot_splash/image="uid://0vtuuii47q4k"
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://6n2sywdqrf6j"
general/2d_panning_strength=1.0

[autoload]

Global="*uid://bgg3rsy7fam86"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/size/always_on_top=true

[editor_plugins]

enabled=PackedStringArray("res://addons/advanced_radial_menu/plugin.cfg")

[global_group]

Units="Player units"
Resource=""
Banks=""
Pit=""
Trees=""
Enemies=""
Buildings=""
Vision=""
Deposits=""
Arboretum=""
Bodies=""
Cities=""

